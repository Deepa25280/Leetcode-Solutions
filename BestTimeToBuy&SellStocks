class Solution {
    public int maxProfit(int[] prices) {
        int bp = prices[0];
        int profit =0;

        for(int i=1; i<prices.length; i++){
            if(bp < prices[i]){
                profit = Math.max(prices[i]-bp,profit);
            }else{
                bp = prices[i];
            }
        }
        return profit;
    }
}
class Solution {
    public boolean asteroidsDestroyed(int mass, int[] asteroids) {
        int n = asteroids.length;
        Arrays.sort(asteroids);
        long ms = mass;

        for (int i = 0; i < n; i++) {
            if (ms >= asteroids[i]) {
                ms += asteroids[i];
            } else if (ms < asteroids[i]) {
               return false;
            }
        }
        return true;
    }
}
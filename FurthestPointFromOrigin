class Solution {
    public int furthestDistanceFromOrigin(String moves) {
        int n = moves.length();

       int l = 0, r = 0;

       int underS = 0;
       
        for(int i=0; i<n; i++){

           char c = moves.charAt(i);

           if(c == 'L') l++;

           else if(c == 'R') r++;

           else underS++;
        }

        int cnt = Math.abs(r-l) + underS;

        return cnt;
    }
}
class Solution {
    public boolean canPlaceFlowers(int[] flowerbed, int n) {
        int l = flowerbed.length;
        int i = 0;
        while (i < l) {
            if ((i == 0 || flowerbed[i - 1] != 1) && flowerbed[i] != 1 && (i == l - 1 || flowerbed[i + 1] != 1)) {
                n = n - 1;
                flowerbed[i] = 1;
            }
            i++;
        }
        if (n <= 0)
            return true;
        else {
            return false;
        }
    }
}
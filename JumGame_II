class Solution {
    public int jump(int[] nums) {
        int maxIdx = 0,  cnt = 0, currRange = 0;

       for(int i=0; i<nums.length-1; i++){
          maxIdx = Math.max(maxIdx , i+nums[i]);

          if(i == currRange){
            cnt++;
            currRange = maxIdx;
          }
    
       }
       return cnt;
    }
}